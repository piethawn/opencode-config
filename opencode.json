{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/moonshotai/kimi-k2.6",
  "default_agent": "chat",
  "skills": {
    "paths": ["~/.config/opencode/skills"]
  },
  "agent": {
    "chat": {
      "mode": "primary",
      "model": "openrouter/moonshotai/kimi-k2.6",
      "description": "Daily driver: general conversation, quick questions, and orchestration",
      "permission": {
        "task": {
          "vault": "allow",
          "code": "allow",
          "plan": "allow",
          "research": "allow"
        },
        "edit": "ask",
        "bash": {
          "ls *": "allow",
          "cat *": "allow",
          "find *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "pwd": "allow",
          "echo *": "allow",
          "which *": "allow",
          "file *": "allow",
          "stat *": "allow",
          "du *": "allow",
          "df *": "allow",
          "ps *": "allow",
          "env": "allow",
          "date": "allow",
          "whoami": "allow",
          "uname *": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git branch*": "allow",
          "*": "ask",
          "rm *": "deny",
          "rm -rf*": "deny"
        }
      }
    },
    "code": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-pro",
      "description": "Writing code, making edits, and refactoring codebases"
    },
    "build": { "disable": true }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "ls *": "allow",
      "cat *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "which *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "ps *": "allow",
      "env": "allow",
      "date": "allow",
      "whoami": "allow",
      "uname *": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch*": "allow",
      "*": "ask",
      "rm *": "deny",
      "rm -rf*": "deny"
    }
  },
  "mcp": {
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "enabled": true,
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      }
    },
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "tavily-mcp@latest"],
      "enabled": true,
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}"
      }
    },
    "apple-reminders": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "/Users/labadmin/.config/opencode/scripts/apple-reminders-mcp.js"
      ],
      "timeout": 60000
    },
    "vault-search": {
      "type": "local",
      "command": ["obsidian-hybrid-search-mcp"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "OBSIDIAN_VAULT_PATH": "/Users/labadmin/Documents/virtual-brain",
        "OPENAI_API_KEY": "{env:OPENAI_API_KEY}",
        "OPENAI_BASE_URL": "https://api.openai.com/v1",
        "OPENAI_EMBEDDING_MODEL": "text-embedding-3-small"
      }
    },
    "jsearch": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.rapidapi.com",
        "--header",
        "x-api-host: jsearch.p.rapidapi.com",
        "--header",
        "x-api-key: {env:RAPIDAPI_KEY}"
      ]
    },
    "youtube-transcript": {
      "type": "local",
      "command": ["npx", "-y", "@kimtaeyoon83/mcp-server-youtube-transcript"],
      "enabled": true,
      "timeout": 60000
    }
  }
}
