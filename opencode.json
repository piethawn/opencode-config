{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/moonshotai/kimi-k2.6",
  "skills": {
    "paths": ["~/.config/opencode/skills"]
  },
  "agent": {
    "code": {
      "mode": "subagent",
      "model": "openrouter/deepseek/deepseek-v4-pro",
      "description": "Writing code, making edits, and refactoring codebases",
      "prompt": "{file:./agents/code.md}"
    },
    "mcp-dev": {
      "mode": "subagent",
      "model": "openrouter/moonshotai/kimi-k2.6",
      "temperature": 0.2,
      "description": "MCP server architect: builds custom MCP servers from scratch AND integrates existing online MCP servers into opencode. Always plans before executing.",
      "prompt": "{file:./agents/mcp-dev.md}"
    },
    "research": {
      "mode": "subagent",
      "model": "openrouter/moonshotai/kimi-k2.6",
      "description": "Research agent. Conducts thorough, multi-source research and returns a concise, well-cited synthesis.",
      "prompt": "{file:./agents/research.md}"
    },
    "vault": {
      "mode": "subagent",
      "model": "openrouter/moonshotai/kimi-k2.6",
      "description": "Vault-knowledge agent. Searches the user\u2019s Obsidian vault, reads relevant notes, and returns cited findings.",
      "prompt": "{file:./agents/vault.md}"
    }
  },
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow"
    },
    "edit": {
      "*": "ask",
      "~/.config/opencode/**": "allow"
    },
    "bash": {
      "ls *": "allow",
      "cat *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "which *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "ps *": "allow",
      "env": "allow",
      "date": "allow",
      "whoami": "allow",
      "uname *": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch*": "allow",
      "*": "ask",
      "rm *": "deny",
      "rm -rf*": "deny"
    }
  },
  "mcp": {
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "enabled": true,
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      }
    },
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "tavily-mcp@latest"],
      "enabled": true,
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}"
      }
    },
    "apple-reminders": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "/Users/labadmin/.config/opencode/scripts/apple-reminders-mcp.js"
      ],
      "timeout": 60000
    },
    "vault-search": {
      "type": "local",
      "command": ["obsidian-hybrid-search-mcp"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "OBSIDIAN_VAULT_PATH": "/Users/labadmin/Documents/virtual-brain",
        "OPENAI_API_KEY": "{env:OPENAI_API_KEY}",
        "OPENAI_BASE_URL": "https://api.openai.com/v1",
        "OPENAI_EMBEDDING_MODEL": "text-embedding-3-small"
      }
    },
    "jsearch": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.rapidapi.com",
        "--header",
        "x-api-host: jsearch.p.rapidapi.com",
        "--header",
        "x-api-key: {env:RAPIDAPI_KEY}"
      ]
    },
    "youtube-transcript": {
      "type": "local",
      "command": ["npx", "-y", "@kimtaeyoon83/mcp-server-youtube-transcript"],
      "enabled": true,
      "timeout": 60000
    }
  }
}
